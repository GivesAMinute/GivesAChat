{
  "name": "headless-chat-browser",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",

    /* ---------------------------------------------------------
       ⭐ PRODUCTION BUILD (Railway will run this)
       --------------------------------------------------------- */
    "build": "npm run build:overlay && npm run build:server",

    /* ---------------------------------------------------------
       ⭐ Build the overlay bundle (Vite)
       --------------------------------------------------------- */
    "build:overlay": "cd overlay/chat && npm install && npm run build",

    /* ---------------------------------------------------------
       ⭐ Backend build (no-op, but Railway requires it)
       --------------------------------------------------------- */
    "build:server": "echo \"Backend build complete\""
  },
  "dependencies": {
    "axios": "1.17.0",
    "eventsource": "4.1.0",
    "express": "4.18.2",
    "node-fetch": "3.3.2",
    "puppeteer": "22.0.0",
    "socket.io-client": "4.8.3",
    "ws": "8.13.0"
  }
}
